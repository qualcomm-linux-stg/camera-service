prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/include

Name: qmmf_camera_metadata
Description: QMMF Camera Metadata Library
Version: @PROJECT_VERSION@
Libs: -L${libdir} -lqmmf_camera_metadata
Cflags: -I${includedir} -I${includedir}/camera-metadata
